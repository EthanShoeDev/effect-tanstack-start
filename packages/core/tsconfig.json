{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023"],
    "moduleDetection": "force",
    "module": "preserve",
    "types": ["node"],
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "verbatimModuleSyntax": true
  }
}
